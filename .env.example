# ============================================
# MetroMatrix Backend — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string (the sole database — see WALLET_DESIGN.md
# for why there is no Redis in this stack)
MONGODB_URI=

# ---- Auth ----
JWT_SECRET=
JWT_EXPIRE=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRE=7d

# ---- CORS ----
CLIENT_URL=http://localhost:19006

# ---- Email (verification, password reset — see WALLET_DESIGN.md /
# HOMESERVICE_REPORT_SECTION.md for why this is email, not Twilio SMS OTP) ----
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ---- Social auth ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=

# ---- Cloudinary (document/photo uploads) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Firebase Admin SDK ----
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ============================================
# Stripe — wallet top-ups, Connect payouts, webhook (see STRIPE_TESTING.md
# for the full run-through: getting test keys, running `stripe listen`,
# test card numbers, and how to verify a top-up actually landed).
# ============================================

# Dashboard → Developers → API keys → Secret key (test mode: sk_test_...).
# Loading this makes src/config/stripe.js construct a real client; without
# it, every Stripe call throws immediately (see stripe.js's fail-fast rule).
STRIPE_SECRET_KEY=

# Dashboard → Developers → API keys → Publishable key (pk_test_...). Not
# read by this backend today (no server-rendered checkout UI) but kept here
# because the mobile app / any future web checkout will need it.
STRIPE_PUBLISHABLE_KEY=

# From `stripe listen --forward-to localhost:5000/api/wallet/webhook` (local
# dev) or Dashboard → Developers → Webhooks → your endpoint → Signing secret
# (deployed). Required for signature verification in stripeWebhook — without
# it every webhook call 400s (see PART A of WALLET_DESIGN.md for exactly
# this failure mode, which is why STRIPE_TESTING.md exists).
STRIPE_WEBHOOK_SECRET=

# Only needed if you add Stripe Connect OAuth (standard accounts). The
# Express-account onboarding flow this codebase actually uses
# (walletController.startConnectOnboarding) does NOT read this var — it's
# here for completeness / if that flow is added later.
STRIPE_CONNECT_CLIENT_ID=

# Public base URL of THIS backend, used to build Stripe's success_url/
# cancel_url and Connect onboarding return/refresh URLs. Must be reachable
# by Stripe's servers (use an ngrok/stripe-cli tunnel URL for local dev,
# your real deployed URL in production).
STRIPE_BACKEND_URL=http://localhost:5000

# Custom URL scheme the mobile app registers (see app.json "scheme" in the
# frontend repo) — the Stripe redirect success/cancel pages deep-link back
# into the app via <this>://wallet/topup-success etc. Falls back to
# 'metromatrix' in code if unset, but set it explicitly so a scheme change
# on the frontend doesn't silently drift from the backend.
APP_DEEP_LINK_SCHEME=metromatrix

# Optional: platform fee percent applied to P2P wallet transfers
# (WalletService.transferFunds). Defaults to 0 if unset.
WALLET_TRANSFER_FEE_PERCENT=0
